{
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "target": "es2020",
        "sourceMap": true,
        "outDir": "dist",
        "strict": true,
        "types": ["node", "jest"]
    },
    "include": [
        "index.ts",
        "__tests__/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
