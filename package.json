    "@types/jest": "^29.5.12",
    "@types/node": "^20.2.5",
    "@eslint/js": "^9.0.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
