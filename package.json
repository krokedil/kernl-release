{
  "version": "1.0.0",
  "name": "kernl-release",
  "description": "Kernl Release Action for GitHub. This action will create a new release for a Plugin hosted on Kernl and deploy a zip file.",
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/github": "^9.1.0",
    "archiver": "^5.3.1",
    "axios": "^1.4.0",
    "form-data": "^4.0.0",
    "glob": "^10.2.7"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^5.3.2",
    "@types/form-data": "^2.5.0",
    "@types/glob": "^8.1.0",
    "@types/node": "^20.2.5",
    "@vercel/ncc": "^0.38.4",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "build": "npx ncc build index.ts --minify -o dist"
  }
